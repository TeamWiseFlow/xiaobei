+ */
+function resolveCamoufoxSessionConfig(opts?: {
+  agentSessionKey?: string;
+  workspaceDir?: string;
+}): CamoufoxCliSessionConfig {
+  const cfg = browserToolDeps.getRuntimeConfig();
+  // proxy/locale/geoip 暂不从 openclaw 配置读（BrowserConfig 无这些字段）；
+  // adapter 默认 geoip=true、无代理、无 locale。后续如需可扩 BrowserConfig。
+  return {
+    session: (opts?.agentSessionKey ?? "openclaw").replace(/[^a-zA-Z0-9_-]/g, "-"),
+    headless: cfg.browser?.headless === true,
+    geoip: true,
+    persistentDir: null,
+  };
