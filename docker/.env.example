# xiaobei Docker Compose environment
#
# Copy this file to .env and fill in your AWK_API_KEY. Docker Compose auto-loads
# .env from this directory, so `docker compose up -d` works without prefixing env
# vars on every command.
#
#   cp .env.example .env
#   # edit .env, replace the placeholder below with your real key
#   docker compose up -d
#
# AWK_API_KEY is the only required setting. Other skill credentials are configured
# later by the running agent in the persistent /root/.openclaw/.env inside the volume.

AWK_API_KEY=__FILL_AWK_API_KEY__

# Optional: override the image tag (defaults to the published image). For local
# validation after running ./scripts/build-image.sh:
# IMAGE=xiaobei:local
